{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug walletd",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/walletd",
      "env": {
        "DATABASE_URL": "postgres://wallet:wallet@localhost:5433/wallet?sslmode=disable",
        "PORT": "8080",
        "LOG_LEVEL": "debug"
      }
    },
    {
      "name": "Debug orderstub",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/orderstub",
      "env": {
        "WALLET_URL": "http://localhost:8080"
      }
    },
    {
      "name": "Debug integration tests (needs Docker)",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/internal/integration"
    }
  ]
}
