meta {
  name: Create Wallet
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/wallets
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-Customer-Id: {{customerId}}
}

body:json {
  {
    "currency": "INR"
  }
}

vars:pre-request {
  baseUrl: localhost:8080
}

script:post-response {
  // Capture the wallet id (created=201 or existing=200) for the other requests.
  if (res.status === 201 || res.status === 200) {
    bru.setVar("walletId", res.body.id);
  }
}
