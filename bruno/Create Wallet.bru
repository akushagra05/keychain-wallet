meta {
  name: Create Wallet
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/wallets
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-Customer-Id: {{customerId}}
}

body:json {
  {
    "currency": "INR"
  }
}

script:post-response {
  // Capture the new wallet id so the other requests can use {{walletId}}.
  if (res.status === 201) {
    bru.setVar("walletId", res.body.id);
  }
}
